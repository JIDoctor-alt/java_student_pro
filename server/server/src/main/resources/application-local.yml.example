# 复制本文件为 application-local.yml（已被 gitignore），填入 API Key
# 或在启动后端前设置环境变量：
#   $env:DEEPSEEK_API_KEY="sk-你的DeepSeek密钥"
#   $env:DASHSCOPE_API_KEY="sk-你的DashScope密钥"
#
# Docker MySQL 本地开发建议用 127.0.0.1，避免 localhost 走 IPv6 连不上：
# spring:
#   datasource:
#     url: jdbc:mysql://127.0.0.1:3306/student_pro?useUnicode=true&characterEncoding=utf-8&serverTimezone=Asia/Shanghai&useSSL=false&allowPublicKeyRetrieval=true
#     username: root
#     password: root

langchain4j:
  open-ai:
    chat-model:
      api-key: sk-你的DeepSeek密钥
    streaming-chat-model:
      api-key: sk-你的DeepSeek密钥

# Pexels 图片素材 API（可选，用于 AI 工作流素材收集）
# 或在启动前：$env:PEXELS_API_KEY="你的Pexels密钥"
app:
  pexels-api-key: 你的Pexels密钥
  ai-model:
    api-key: sk-你的DeepSeek密钥
    scenarios:
      html-stream:
        api-key: sk-你的DashScope密钥
      code-retry:
        api-key: sk-你的DashScope密钥
      vue-agent:
        model-name: deepseek-chat
        # 复杂 Vue 工程可改为 deepseek-reasoner（更强、更贵）
        # model-name: deepseek-reasoner
