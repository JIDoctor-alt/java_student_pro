[Unit]
Description=CODE Student Pro Backend
After=network.target docker.service

[Service]
Type=simple
User=root
WorkingDirectory=/opt/code-student-pro
Environment=SPRING_PROFILES_ACTIVE=prod
Environment=LANG=en_US.UTF-8
Environment=LC_ALL=en_US.UTF-8
Environment=JAVA_TOOL_OPTIONS=-Dfile.encoding=UTF-8 -Dsun.jnu.encoding=UTF-8
Environment=DEEPSEEK_API_KEY=
Environment=MYSQL_PASSWORD=root
ExecStart=/usr/bin/java -Dfile.encoding=UTF-8 -Dsun.jnu.encoding=UTF-8 -jar /opt/code-student-pro/server.jar
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
